<article class="event-card">
    <a class="event-card-link" href="{{ path('app_events_show', { id: event.id }) }}" aria-label="Apri dettaglio evento {{ event.title }}">
        <img src="{{ asset(event.coverImagePath) }}" alt="Copertina evento {{ event.title }}" class="event-cover">
        <div class="event-body">
            <div class="event-meta">
                <span>{{ event.formattedDate }}</span>
                <span>{{ event.location }}</span>
            </div>
            <h3>{{ event.title }}</h3>
            <p>{{ event.description }}</p>

            {% if event.images is not empty %}
                <div class="event-gallery">
                    {% for image in event.images %}
                        {% if image.isVideo %}
                            <video src="{{ asset(image.publicPath) }}" muted playsinline preload="metadata" aria-label="{{ image.altText }}"></video>
                        {% else %}
                            <img src="{{ asset(image.publicPath) }}" alt="{{ image.altText }}">
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </a>
</article>
