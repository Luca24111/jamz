<article class="associate-card">
    <div class="associate-meta">
        <span>{{ associate.membershipNumber }}</span>
        <span>{{ associate.formattedJoinDate }}</span>
    </div>
    <h3>{{ associate.fullName }}</h3>
    <p>{{ associate.instrument }} · {{ associate.city }}</p>
    <p>{{ associate.shortBio }}</p>
</article>
