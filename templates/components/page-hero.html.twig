<section class="page-hero">
    <div class="shell page-hero-inner">
        {% if hero.eyebrow is defined %}
            <p class="eyebrow">{{ hero.eyebrow }}</p>
        {% endif %}
        <h1>
            {{ hero.title
                |replace({
                    '[[Programmiamo]]': '<span class="hero-highlight">Programmiamo</span>',
                    '[[costruiamo]]': '<span class="hero-highlight">costruiamo</span>',
                    '[[suonare con noi]]': '<span class="hero-highlight">suonare con noi</span>',
                    '[[spazio]]': '<span class="hero-highlight">spazio</span>',
                    '[[musica]]': '<span class="hero-highlight">musica</span>',
                    '[[occasioni]]': '<span class="hero-highlight">occasioni</span>',
                    '[[persone]]': '<span class="hero-highlight">persone</span>',
                    '[[visione]]': '<span class="hero-highlight">visione</span>',
                    '[[relazioni]]': '<span class="hero-highlight">relazioni</span>',
                    '[[passati]]': '<span class="hero-highlight">passati</span>',
                    '[[futuri]]': '<span class="hero-highlight">futuri</span>',
                    '[[culturale]]': '<span class="hero-highlight">culturale</span>',
                    '[[artistica]]': '<span class="hero-highlight">artistica</span>',
                    '[[Statuto]]': '<span class="hero-highlight">Statuto</span>',
                    '[[online]]': '<span class="hero-highlight">online</span>',
                    '[[Suona]]': '<span class="hero-highlight">Suona</span>'
                })
                |raw
            }}
        </h1>
        {% if hero.intro is defined %}
            <p class="page-intro">{{ hero.intro }}</p>
        {% endif %}

        {% if (hero.primary_cta is defined and hero.primary_cta) or (hero.secondary_cta is defined and hero.secondary_cta) %}
            <div class="hero-actions">
                {% if hero.primary_cta is defined and hero.primary_cta %}
                    <a class="button button-primary" href="{{ hero.primary_cta.path }}">{{ hero.primary_cta.label }}</a>
                {% endif %}
                {% if hero.secondary_cta is defined and hero.secondary_cta %}
                    <a class="button button-secondary" href="{{ hero.secondary_cta.path }}">{{ hero.secondary_cta.label }}</a>
                {% endif %}
            </div>
        {% endif %}
    </div>
</section>
