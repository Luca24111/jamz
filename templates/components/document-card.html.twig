<article class="document-card">
    <p class="eyebrow">{{ document.type|replace({'_': ' '})|title }}</p>
    <h3>{{ document.title }}</h3>
    <p>File: {{ document.fileName }}</p>
    <p>Caricato il {{ document.formattedUploadedAt }}</p>
    <div class="document-actions">
        <a class="button button-primary" href="{{ asset(document.publicPath) }}" target="_blank" rel="noreferrer">Apri file</a>
        <a class="button button-secondary" href="{{ asset(document.publicPath) }}" download>Scarica</a>
    </div>
</article>
