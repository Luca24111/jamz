{% extends 'layout/base.html.twig' %}

{% block content %}
    {% include 'components/page-hero.html.twig' with {
        hero: {
            eyebrow: 'Consiglio direttivo',
            title: 'Le persone che coordinano visione, produzione e relazioni dell’associazione.',
            intro: 'Ogni ruolo unisce competenze organizzative e prossimità con la scena musicale locale.'
        }
    } %}

    <section class="shell board-grid section-spacing">
        {% for member in members %}
            {% include 'components/board-card.html.twig' with { member: member } %}
        {% else %}
            <p class="empty-state">Nessun membro presente nel database.</p>
        {% endfor %}
    </section>
{% endblock %}
