{% extends 'layout/base.html.twig' %}

{% block content %}
    {% include 'components/page-hero.html.twig' with { hero: hero } %}

    <section class="shell narrative-grid section-spacing">
        {% for section in sections %}
            <article class="narrative-card">
                <h2>{{ section.title }}</h2>
                <p>{{ section.body }}</p>
            </article>
        {% endfor %}
    </section>
{% endblock %}
