{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "doctrine/dbal": "^3.10",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/orm": "^2.20",
        "symfony/asset": "^6.4",
        "symfony/console": "^6.4",
        "symfony/dotenv": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/runtime": "^6.4",
        "symfony/twig-bundle": "^6.4",
        "symfony/yaml": "^6.4",
        "twig/twig": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    }
}
