# Copia questo file in .env. Non inserire mai segreti nei file *.example.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-only-for-local-development
APP_NAME=Jamz
APP_TIMEZONE=Europe/Rome

# Valori specifici in .env.dev oppure .env.prod.
DATABASE_URL="mysql://jamz:jamzpass@127.0.0.1:3306/jamz?serverVersion=8.0&charset=utf8mb4"

MAIL_TO=info@example.test
MAIL_FROM=noreply@example.test
MAIL_TRANSPORT=log
SOCIAL_INSTAGRAM=https://instagram.com/
SOCIAL_TELEGRAM=https://t.me/
