Options -Indexes
RewriteEngine On

# Impedisce l'accesso diretto a file nascosti e configurazioni locali.
RewriteRule "(^|/)\.(?!well-known(?:/|$))" - [F,L]

# Compatibilita con hosting che non consentono di impostare public/ come web root.
RewriteRule ^public/ - [L]
RewriteRule ^(.*)$ public/$1 [L]
